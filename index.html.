<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Lost & Found</title>
  <script src="https://cdn.jsdelivr.net/npm/@supabase/supabase-js@2"></script>
  <style>
    body { font-family: sans-serif; max-width: 800px; margin: 0 auto; padding: 20px; }
    .item-card { border: 1px solid #ddd; border-radius: 8px; padding: 16px; margin: 10px 0; }
    .badge { padding: 3px 10px; border-radius: 20px; font-size: 12px; font-weight: bold; }
    .lost { background: #fee2e2; color: #991b1b; }
    .found { background: #dcfce7; color: #166534; }
    input, textarea, select { width: 100%; padding: 8px; margin: 6px 0 12px; border: 1px solid #ddd; border-radius: 6px; font-size: 14px; }
    button { padding: 10px 20px; background: #2563eb; color: white; border: none; border-radius: 6px; cursor: pointer; font-size: 14px; }
  </style>
</head>
<body>
  <h1>Lost & Found</h1>

  <h2>Report an item</h2>
  <input id="title" placeholder="Item name (e.g. Blue backpack)">
  <textarea id="desc" placeholder="Description"></textarea>
  <input id="location" placeholder="Where was it lost/found?">
  <input id="contact" placeholder="Your email">
  <select id="status">
    <option value="lost">I lost this</option>
    <option value="found">I found this</option>
  </select>
  <button onclick="submitItem()">Submit</button>

  <h2 style="margin-top:30px">All items</h2>
  <input id="search" placeholder="Search..." oninput="filterItems()">
  <div id="items-list"></div>

  <script>
    const { createClient } = supabase;
    const db = createClient('YOUR_SUPABASE_URL', 'YOUR_ANON_KEY');
    let allItems = [];

    async function loadItems() {
      const { data } = await db.from('items').select('*').order('created_at', { ascending: false });
      allItems = data || [];
      renderItems(allItems);
    }

    function renderItems(items) {
      document.getElementById('items-list').innerHTML = items.map(item => `
        <div class="item-card">
          <span class="badge ${item.status}">${item.status.toUpperCase()}</span>
          <h3>${item.title}</h3>
          <p>${item.description}</p>
          <p>Location: ${item.location}</p>
          <p>Contact: ${item.contact}</p>
        </div>`).join('');
    }

    function filterItems() {
      const q = document.getElementById('search').value.toLowerCase();
      renderItems(allItems.filter(i => i.title.toLowerCase().includes(q) || i.description.toLowerCase().includes(q)));
    }

    async function submitItem() {
      const item = {
        title: document.getElementById('title').value,
        description: document.getElementById('desc').value,
        location: document.getElementById('location').value,
        contact: document.getElementById('contact').value,
        status: document.getElementById('status').value
      };
      if (!item.title) { alert('Please enter an item name'); return; }
      await db.from('items').insert([item]);
      alert('Item submitted!');
      loadItems();
    }

    loadItems();
  </script>
</body>
</html>

         
